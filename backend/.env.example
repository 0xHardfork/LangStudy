# Docker socket — Docker Desktop (default)
# DOCKER_HOST=unix:///var/run/docker.sock

# Docker socket — Colima
# DOCKER_HOST=unix:///Users/<you>/.colima/<profile>/docker.sock
# TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=unix:///Users/<you>/.colima/<profile>/docker.sock

# Disable Ryuk reaper (required for Colima / rootless Docker)
# TESTCONTAINERS_RYUK_DISABLED=true
